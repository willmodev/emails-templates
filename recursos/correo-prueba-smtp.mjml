<mjml lang="es">
  <mj-head>
    <mj-title>Correo de prueba SMTP - Gestión de Riesgos</mj-title>
    <mj-preview>Comprobación de la configuración del servidor de correo</mj-preview>

    <mj-font name="Poppins" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" />

    <mj-attributes>
      <mj-all font-family="Poppins, Arial, sans-serif" />
      <mj-text padding="0 40px" color="#1a1a1a" font-size="12px" line-height="16px" />
      <mj-section padding="0" />
      <mj-button font-family="Poppins, Arial, sans-serif" />
    </mj-attributes>

    <mj-html-attributes>
      <mj-selector path=".email-heading div">
        <mj-html-attribute name="role">heading</mj-html-attribute>
        <mj-html-attribute name="aria-level">1</mj-html-attribute>
      </mj-selector>
    </mj-html-attributes>

    <mj-style inline="inline">
      .logo-max {
        text-align: center !important;
      }
      .logo-max img {
        max-width: 250px !important;
        max-height: 126px !important;
        width: auto !important;
        height: auto !important;
        margin: 0 auto !important;
        display: block !important;
      }
    </mj-style>
  </mj-head>

  <mj-body background-color="#FFFFFF" width="600px">

    <!-- Header limpio de 80px -->
    <mj-section background-color="{primaryColor}" padding="0">
      <mj-column>
        <mj-spacer height="80px" />
      </mj-column>
    </mj-section>

    <!-- Marca en cuerpo -->
    <mj-section background-color="#FFFFFF" padding="40px 0 0 0">
      <mj-column>
        <mj-image css-class="logo-max" src="{logoUrl}" alt="Gestión de Crisis" align="center" padding="0" />
      </mj-column>
    </mj-section>

    <!-- Título principal -->
    <mj-section background-color="#FFFFFF" padding="24px 0 0 0">
      <mj-column>
        <mj-text
          css-class="email-heading"
          font-size="16px"
          font-weight="700"
          color="{primaryColor}"
          align="center"
          padding="0 40px"
          line-height="22px"
          letter-spacing="-0.32px"
        >
          Correo de prueba SMTP
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Saludo -->
    <mj-section background-color="#FFFFFF" padding="24px 0 0 0">
      <mj-column>
        <mj-text padding="0 40px" font-size="12px" font-weight="400" line-height="16px">
          Estimado/a, {username}
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Mensaje principal -->
    <mj-section background-color="#FFFFFF" padding="12px 0 0 0">
      <mj-column>
        <mj-text padding="0 40px" font-size="12px" font-weight="400" line-height="16px">
          Si estas leyendo este mensaje, la configuración del servidor del correo (SMTP) es correcta y el envío desde la aplicación de Gestión de crisis está funcionando.
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Caja de confirmación -->
    <mj-section background-color="#FFFFFF" padding="24px 40px 0 40px">
      <mj-column background-color="{primaryLightBg}" border-radius="20px" padding="28px 20px">
        <mj-text
          align="center"
          font-size="16px"
          font-weight="600"
          color="{primaryColor}"
          line-height="24px"
          letter-spacing="-0.32px"
          padding="0 10px 12px 10px"
        >
          Configuración verificada
        </mj-text>
        <mj-text
          align="center"
          font-size="16px"
          font-weight="600"
          color="#1a1a1a"
          line-height="28px"
          padding="0 10px"
        >
          El servidor SMTP responde correctamente y los correos se están enviando sin problemas.
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Aviso -->
    <mj-section background-color="#FFFFFF" padding="24px 0 40px 0">
      <mj-column>
        <mj-text padding="0 40px" font-size="12px" font-weight="400" line-height="16px" color="#1f2937" font-style="italic">
          Este mensaje se generó automáticamente al usar la opción «Enviar correo de prueba» en la administración del sistema. No es necesario responder.
        </mj-text>
      </mj-column>
    </mj-section>

  </mj-body>
</mjml>
