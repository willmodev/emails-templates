<mjml lang="es">
  <mj-head>
    <mj-title>Reestablece tu contraseña - Gestión de Riesgos</mj-title>
    <mj-preview>Usa este código para reestablecer tu contraseña</mj-preview>

    <mj-font name="Poppins" href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" />

    <mj-attributes>
      <mj-all font-family="Poppins, Arial, sans-serif" />
      <mj-text padding="0 40px" color="#1a1a1a" font-size="12px" line-height="16px" />
      <mj-section padding="0" />
      <mj-button font-family="Poppins, Arial, sans-serif" />
    </mj-attributes>

    <mj-html-attributes>
      <mj-selector path=".email-heading div">
        <mj-html-attribute name="role">heading</mj-html-attribute>
        <mj-html-attribute name="aria-level">1</mj-html-attribute>
      </mj-selector>
    </mj-html-attributes>

    <mj-style inline="inline">
      .logo-max {
        text-align: center !important;
      }
      .logo-max img {
        max-width: 250px !important;
        max-height: 126px !important;
        width: auto !important;
        height: auto !important;
        margin: 0 auto !important;
        display: block !important;
      }
    </mj-style>
  </mj-head>

  <mj-body background-color="#FFFFFF" width="600px">

    <!-- Header limpio de 80px -->
    <mj-section background-color="{primaryColor}" padding="0">
      <mj-column>
        <mj-spacer height="80px" />
      </mj-column>
    </mj-section>

    <!-- Marca en cuerpo -->
    <mj-section background-color="#FFFFFF" padding="40px 0 0 0">
      <mj-column>
        <mj-image css-class="logo-max" src="{logoUrl}" alt="Gestión de Crisis" align="center" padding="0" />
      </mj-column>
    </mj-section>

    <!-- Título principal -->
    <mj-section background-color="#FFFFFF" padding="24px 0 0 0">
      <mj-column>
        <mj-text
          css-class="email-heading"
          font-size="16px"
          font-weight="700"
          color="{primaryColor}"
          align="center"
          padding="0 40px"
          line-height="22px"
          letter-spacing="-0.32px"
        >
          Reestablece tu contraseña
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Asunto -->
    <mj-section background-color="#FFFFFF" padding="36px 0 0 0">
      <mj-column>
        <mj-text padding="0 40px" font-size="12px" font-weight="700" line-height="16px" color="#1a1a1a">
          Asunto
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section background-color="#FFFFFF" padding="12px 0 0 0">
      <mj-column>
        <mj-text padding="0 40px" font-size="12px" font-weight="400" line-height="16px" color="#4b5563">
          Solicitud de restablecimiento de contraseña
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Descripción -->
    <mj-section background-color="#FFFFFF" padding="36px 0 0 0">
      <mj-column>
        <mj-text padding="0 40px" font-size="12px" font-weight="700" line-height="16px" color="#1a1a1a">
          Descripción
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section background-color="#FFFFFF" padding="12px 0 0 0">
      <mj-column>
        <mj-text padding="0 40px" font-size="12px" font-weight="400" line-height="16px" color="#4b5563">
          Estimado/a, {username}
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section background-color="#FFFFFF" padding="24px 0 0 0">
      <mj-column>
        <mj-text padding="0 40px" font-size="12px" font-weight="400" line-height="16px" color="#4b5563">
          Hemos recibido tu solicitud para reestablecer la contraseña de tu cuenta en la aplicación de gestión de crisis.
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- CTA -->
    <mj-section background-color="#FFFFFF" padding="32px 0 0 0">
      <mj-column>
        <mj-text
          align="center"
          font-size="12px"
          font-weight="700"
          color="{primaryColor}"
          line-height="16px"
          padding="0 40px"
        >
          Haz clic en el siguiente enlace seguro para crear una nueva clave de acceso
        </mj-text>
      </mj-column>
    </mj-section>

    <mj-section background-color="#FFFFFF" padding="20px 0 0 0">
      <mj-column>
        <mj-button
          href="{ctaUrl}"
          background-color="{primaryColor}"
          color="#ffffff"
          font-size="14px"
          font-weight="600"
          line-height="20px"
          border-radius="6px"
          inner-padding="10px 18px"
          padding="0 40px"
          width="340px"
        >
          <img src="https://gcrisis.blob.core.windows.net/emails/arrow-right-circle.png" alt="" width="24" height="24" style="vertical-align:middle;margin-right:10px;" />Administrador Gestión de Crisis
        </mj-button>
      </mj-column>
    </mj-section>

    <!-- Caja OTP -->
    <mj-section background-color="#FFFFFF" padding="32px 40px 0 40px">
      <mj-column background-color="{primaryLightBg}" border-radius="20px" padding="30px 20px 34px 20px">
        <mj-text
          align="center"
          font-size="16px"
          font-weight="600"
          color="{primaryColor}"
          line-height="24px"
          letter-spacing="-0.32px"
          padding="0 10px 20px 10px"
        >
          Código de restablecimiento
        </mj-text>
        <mj-text
          align="center"
          font-size="52px"
          font-weight="600"
          color="#17223a"
          line-height="52px"
          letter-spacing="8px"
          padding="0 10px"
        >
          {otpCode}
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Nota de validez -->
    <mj-section background-color="#FFFFFF" padding="28px 0 48px 0">
      <mj-column>
        <mj-text padding="0 40px" font-size="12px" font-weight="400" line-height="16px" color="#4b5563">
          Este código es válido por {otpValidityText}. Si no realizaste ninguna solicitud, puedes ignorar este mensaje.
        </mj-text>
      </mj-column>
    </mj-section>

  </mj-body>
</mjml>
